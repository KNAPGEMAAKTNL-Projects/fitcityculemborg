---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroVideo from '@components/sections/HeroVideo.astro';
import PricingGrid from '@components/sections/PricingGrid.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Container from '@components/ui/Container.astro';
import USPCard from '@components/sections/USPCard.astro';


---

<BaseLayout
  title="Ladies Only Fitness Culemborg"
  description="Ladies Only fitness in Culemborg. Eigen damesvloer met volledige privacy, vanaf 20,50 per maand. Altijd begeleiding, gratis parkeren."
  theme="ladies"
>
  <HeroVideo
    headline="LADIES ONLY"
    subheadline="Een eigen vloer, alleen voor vrouwen"
    ctaText="WORD NU LID"
    ctaLink="/signup"
    secondaryCtaText="BEKIJK PRIJZEN"
    secondaryCtaLink="#pricing"
  />

  <section class="py-16 md:py-24">
    <Container>
      <SectionHeading
        title="Over Ladies Only"
        subtitle="Volledig uitgerust, volledige privacy"
      />
      <div class="max-w-3xl mx-auto space-y-6 text-center">
        <p class="text-text-muted leading-relaxed">
          Een eigen trainingsvloer, alleen voor vrouwen. Volledig uitgerust met alle apparatuur die je nodig hebt. In je eigen ruimte, op je eigen tempo.
        </p>
        <p class="text-text-muted leading-relaxed">
          Dezelfde FitCity energie, maar met de privacy die je zoekt. Geen wachten, geen ongemak. Gewoon trainen.
        </p>
      </div>
    </Container>
  </section>

  <section class="py-16 md:py-24 bg-bg-main">
    <Container>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <USPCard
          icon="users"
          title="Eigen Ruimte"
          description="Aparte damesvloer beneden"
        />
        <USPCard
          icon="dumbbell"
          title="Volledige Uitrusting"
          description="Alle apparaten en gewichten die je nodig hebt"
        />
        <USPCard
          icon="check"
          title="Privacy"
          description="Train in een comfortabele omgeving"
        />
      </div>
    </Container>
  </section>

  <section id="pricing" class="py-16 md:py-24">
    <Container>
      <SectionHeading
        title="Ladies Only Prijzen"
        subtitle="Speciale prijzen voor de damesvloer"
      />
    </Container>
    <PricingGrid
      category="ladies"
      highlightedId="ladies-jaar"
    />
  </section>
</BaseLayout>
